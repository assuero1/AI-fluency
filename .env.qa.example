# QA-only environment. Copy this through scripts/create-qa-env.mjs; never add secrets here.
APP_ENV=qa
APP_URL=http://localhost:3012
QA_RUN_NAMESPACE=AI_FLUENCY_QA
# Test runners set this dynamically from each fixture manifest.
AI_FLUENCY_USER_ID=
TEABLE_BASE_ID=

# All service credentials and table IDs are populated from the local secure environment.
TEABLE_BASE_URL=
TEABLE_API_KEY=
AI_BASE_URL=
AI_API_KEY=
AI_CHAT_MODEL=
KOKORO_BASE_URL=
KOKORO_API_KEY=
KOKORO_DEFAULT_VOICE=af_heart
KOKORO_OUTPUT_FORMAT=mp3
KOKORO_SPEED=1.08
KOKORO_VOICE_EN=af_heart
KOKORO_VOICE_ES=ef_dora
KOKORO_VOICE_FR=ff_siwis
KOKORO_VOICE_IT=if_sara
KOKORO_VOICE_PT=pf_dora
FLASHCARD_ACTIVE_RECALL_ENABLED=true
