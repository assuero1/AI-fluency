# AI Fluency environment template
# Copy to .env.local during implementation. Never commit real secrets.

# App
APP_URL=http://localhost:3000
APP_ENV=development
# Recommended whenever the Users table contains an existing personal profile.
# The server refuses to guess when more than one user record exists.
AI_FLUENCY_USER_ID=
ENCRYPTION_SECRET=replace-with-a-long-random-secret
# Production-only attestation used by the Phase 8 host gate after mounting the volume.
AUDIO_CACHE_PERSISTENT=false

# Teable running on VPS
TEABLE_BASE_URL=https://your-teable.example.com
TEABLE_API_KEY=replace-with-teable-api-key
# TEABLE_TOKEN is also supported as an alias for TEABLE_API_KEY.
# TEABLE_TOKEN=replace-with-teable-api-key
TEABLE_BASE_ID=replace-with-teable-base-id

# Teable table ids for AI Fluency
TEABLE_USERS_TABLE_ID=
TEABLE_LANGUAGE_PROFILES_TABLE_ID=
TEABLE_AI_PROVIDER_SETTINGS_TABLE_ID=
TEABLE_VOICE_PROVIDER_SETTINGS_TABLE_ID=
TEABLE_CONVERSATIONS_TABLE_ID=
TEABLE_MESSAGES_TABLE_ID=
TEABLE_CORRECTIONS_TABLE_ID=
TEABLE_WORDS_TABLE_ID=
TEABLE_WORD_OCCURRENCES_TABLE_ID=
TEABLE_DAILY_FEEDBACKS_TABLE_ID=
TEABLE_TOPICS_TABLE_ID=
TEABLE_PRACTICE_SESSIONS_TABLE_ID=
TEABLE_APP_EVENTS_TABLE_ID=

# Kokoro running on VPS
KOKORO_BASE_URL=https://your-kokoro.example.com
KOKORO_API_KEY=replace-with-kokoro-api-key
KOKORO_DEFAULT_VOICE=af_heart
KOKORO_OUTPUT_FORMAT=mp3
KOKORO_SPEED=1.08
KOKORO_VOICE_EN=af_heart
KOKORO_VOICE_ES=ef_dora
KOKORO_VOICE_FR=ff_siwis
KOKORO_VOICE_IT=if_sara
KOKORO_VOICE_PT=pf_dora
# Comma-separated server allowlists. Omit to allow only the defaults above.
KOKORO_ALLOWED_VOICES=af_heart,ef_dora,ff_siwis,if_sara,pf_dora
KOKORO_ALLOWED_FORMATS=mp3
# Persistent server-side cache for Kokoro responses. Mount this directory as a volume in production.
AUDIO_CACHE_DIR=.audio-cache
AUDIO_CACHE_MAX_MB=200
AUDIO_CACHE_MAX_AGE_DAYS=30

# AI provider for conversation/correction/recommendations
AI_PROVIDER=deepseek
AI_BASE_URL=https://api.deepseek.com/v1
AI_API_KEY=replace-with-ai-provider-api-key
AI_CHAT_MODEL=deepseek-v4-flash
AI_TEMPERATURE=0.4
AI_MAX_TOKENS=1200

# Speech-to-text uses the browser/cellphone native recognition API.
# No STT provider, URL, API key, or model environment variables are required.

# Optional Phase 8 private-origin access header. Keep the value server-only.
PHASE8_ACCESS_HEADER_NAME=
PHASE8_ACCESS_HEADER_VALUE=
